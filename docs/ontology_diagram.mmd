    PAPER }o--o{ INJURY : studiesInjury
    INJURY }o--|| BODYPART : affectsBodyPart
    PAPER }o--o{ BODYPART : focusesOnBodyPart
    PAPER }o--o{ TREATMENTMETHOD : describesTreatment
    TREATMENTMETHOD }o--o{ INJURY : appliedToInjury
    PAPER }o--o{ SPORT : evaluatedInSport
    PAPER }o--|| VENUE : publishedIn
    PAPER }o--o{ CLINICALMEASURE : reportsMeasure

    PAPER }o--o{ EXTERNALRESOURCE : sameAsExternal
    PERSON }o--o{ EXTERNALRESOURCE : sameAsExternal
